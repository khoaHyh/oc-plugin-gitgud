{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "oc-plugin-gitgud",
  "version": "0.1.4",
  "type": "module",
  "files": [
    "action-catalog.ts",
    "change-set.ts",
    "commit-message.ts",
    "config.ts",
    "git.ts",
    "runtime.ts",
    "status-dialog.tsx",
    "tui.tsx",
    "types.ts",
    "view-model.ts"
  ],
  "scripts": {
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/khoaHyh/oc-plugin-gitgud.git"
  },
  "exports": {
    "./tui": {
      "import": "./tui.tsx",
      "config": {
        "enabled": true,
        "workflow": "auto",
        "replace_sidebar_files": false,
        "confirm_push": true,
        "confirm_stage_all_on_commit": true,
        "commit_agent": "",
        "commit_model": "",
        "commit_system_instructions": "",
        "keybinds": {
          "open_status": "<leader>v",
          "stage_all": "<leader>A",
          "unstage_all": "<leader>U",
          "commit": "<leader>C",
          "push": "<leader>P",
          "graphite_create": "none",
          "graphite_modify": "none",
          "graphite_submit_stack": "none",
          "graphite_sync": "none",
          "graphite_up": "none",
          "graphite_down": "none",
          "refresh": "f5"
        }
      }
    }
  },
  "engines": {
    "opencode": ">=1.3.14"
  },
  "devDependencies": {
    "@types/node": "16.9.1",
    "oxfmt": "0.41.0",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "*",
    "@opentui/core": "*",
    "@opentui/solid": "*",
    "solid-js": "*"
  }
}
