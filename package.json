{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "oc-plugin-gitgud",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "fmt": "oxfmt --write .",
    "fmt:check": "oxfmt --check .",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/khuynh/oc-plugin-gitgud.git"
  },
  "exports": {
    "./tui": {
      "import": "./tui.tsx",
      "config": {
        "enabled": true,
        "replace_sidebar_files": false,
        "confirm_push": true,
        "confirm_stage_all_on_commit": true,
        "commit_agent": "build"
      }
    }
  },
  "engines": {
    "opencode": ">=1.3.14"
  },
  "devDependencies": {
    "@types/node": "16.9.1",
    "oxfmt": "0.41.0",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": "*",
    "@opentui/core": "*",
    "@opentui/solid": "*",
    "solid-js": "*"
  }
}
